# OBS WebSocket connection (obs-websocket v5, built into OBS 28+).
# In OBS: Tools > WebSocket Server Settings. Copy the values here.
# Never commit your real .env — copy this file to .env and fill it in.
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=

# HTTP port the app (SvelteKit + Socket.io) listens on in production (npm start).
PORT=3000

# Max upload size in production (logo uploads). Default 25M if unset. adapter-node
# would otherwise cap request bodies at 512K and silently reject larger images.
BODY_SIZE_LIMIT=25M
